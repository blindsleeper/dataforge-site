---
import Layout from '../layouts/Layout.astro';

const featured = {
  client:   'Adams Jones Law Firm',
  location: 'Wichita, KS',
  service:  'Webflow Redesign & CMS Buildout',
  year:     '2025',
  status:   'Live',
  url:      'https://www.adamsjones.com',
  desc:     'A prominent Wichita law firm needed a site that matched their reputation — professional, fast, and fully manageable by their own team. We rebuilt the entire site in Webflow with a structured CMS, a mobile-first layout, and zero developer dependency going forward.',
  deliverables: [
    'New site architecture & information hierarchy',
    'Mobile-first responsive design across all breakpoints',
    'Webflow CMS buildout with client-editable content areas',
    'Attorney profiles, practice area pages, and blog system',
    'Client training & handoff documentation',
  ],
  tags: ['Webflow', 'CMS', 'Mobile Optimization', 'Web Design', 'Law', 'Wichita'],
};

const placeholders = [
  {
    category: 'Data Analytics',
    type:     'Dashboard & Reporting Pipeline',
    sector:   'Manufacturing',
    status:   'In preparation',
  },
  {
    category: 'Systems & Automation',
    type:     'Workflow Automation Build',
    sector:   'Professional Services',
    status:   'Available under NDA',
  },
  {
    category: 'AI-Augmented Workflows',
    type:     'Internal LLM Tool',
    sector:   'Healthcare Adjacent',
    status:   'Coming soon',
  },
];
---

<Layout title="Portfolio">

<!-- ── PAGE HERO ── -->
<section class="page-hero">
  <div class="page-hero-grid"></div>
  <div class="page-hero-glow"></div>
  <div class="page-hero-inner">
    <div class="page-eyebrow fade-up d1">// Portfolio</div>
    <h1 class="page-headline fade-up d2">
      My<br><em>Work</em>
    </h1>
    <p class="page-sub fade-up d3">
      Every project is scoped to a real problem and built to outlast the engagement.
      Client results, not concept decks.
    </p>
    <div class="page-hero-meta fade-up d4">
      <div class="meta-item"><span class="meta-dot"></span>1 Live Case Study</div>
      <div class="meta-divider"></div>
      <div class="meta-item"><span class="meta-dot"></span>More Coming Soon</div>
      <div class="meta-divider"></div>
      <div class="meta-item"><span class="meta-dot"></span>Wichita, KS</div>
    </div>
  </div>
</section>

<!-- ── FEATURED PROJECT ── -->
<div style="border-bottom: 1px solid var(--border);">
  <div class="section">
    <div class="section-header">
      <span class="section-num">01</span>
      <h2 class="section-title">Featured<br><em>Project</em></h2>
    </div>
    <div class="section-rule"></div>

    <div class="featured-card fade-up d2">
      <div class="featured-accent-bar"></div>

      <!-- Card header row -->
      <div class="featured-header">
        <span class="featured-eyebrow">// Featured Project</span>
        <span class="status-live">
          <span class="status-dot"></span>Live
        </span>
      </div>

      <!-- Card body: info + preview -->
      <div class="featured-body">
        <div class="featured-info">
          <div class="featured-client">{featured.client}</div>
          <div class="featured-location">{featured.location} &nbsp;·&nbsp; {featured.year}</div>
          <div class="featured-service">{featured.service}</div>
          <p class="featured-desc">{featured.desc}</p>

          <div class="featured-deliverables-label">Deliverables</div>
          <ul class="featured-deliverables">
            {featured.deliverables.map((d) => (
              <li>{d}</li>
            ))}
          </ul>

          <div class="featured-footer">
            <div class="featured-tags">
              {featured.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
            <a
              href="https://www.adamsjones.com"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-ghost featured-cta"
            >
              View Live Site →
            </a>
          </div>
        </div>

        <!-- Abstract browser preview -->
        <div class="featured-preview" aria-hidden="true">
          <div class="browser-frame">
            <div class="browser-bar">
              <div class="browser-dots">
                <span></span><span></span><span></span>
              </div>
              <div class="browser-url">adamsjones.com</div>
            </div>
            <div class="browser-body">
              <div class="brow-nav">
                <div class="brow-logo"></div>
                <div class="brow-nav-links">
                  <div class="brow-line short"></div>
                  <div class="brow-line short"></div>
                  <div class="brow-line short accent"></div>
                </div>
              </div>
              <div class="brow-hero">
                <div class="brow-line xl"></div>
                <div class="brow-line lg"></div>
                <div class="brow-line md muted"></div>
                <div class="brow-line sm muted"></div>
                <div class="brow-btn"></div>
              </div>
              <div class="brow-cards">
                <div class="brow-card"></div>
                <div class="brow-card"></div>
                <div class="brow-card"></div>
              </div>
            </div>
          </div>
          <div class="preview-tag">Live Site</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── COMING SOON CARDS ── -->
<div style="background: var(--bg2); border-bottom: 1px solid var(--border);">
  <div class="section">
    <div class="section-header">
      <span class="section-num">02</span>
      <h2 class="section-title">More<br><em>Incoming</em></h2>
    </div>
    <div class="section-rule"></div>

    <div class="placeholders-grid">
      {placeholders.map((p, i) => (
        <div class="placeholder-card">
          <div class="placeholder-lock" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="11" width="18" height="11" rx="1"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div class="placeholder-num">0{i + 2}</div>
          <div class="placeholder-category">{p.category}</div>
          <div class="placeholder-type">{p.type}</div>
          <div class="placeholder-sector">
            <span class="placeholder-sector-label">Sector</span>
            {p.sector}
          </div>
          <div class="placeholder-status">
            <span class="status-dot-dim"></span>
            {p.status}
          </div>
        </div>
      ))}
    </div>

    <p class="placeholders-note">
      Additional case studies are being prepared. Some engagements are under NDA — results are available on request.
    </p>
  </div>
</div>

<!-- ── INTERNAL TOOLS ── -->
<div style="background: var(--bg); border-bottom: 1px solid var(--border);">
  <div class="section">
    <div class="section-header">
      <span class="section-num">03</span>
      <h2 class="section-title">Built Because<br><em>They Needed to Exist</em></h2>
    </div>
    <div class="section-rule"></div>

    <p class="tools-intro">
      Tools I built to solve recurring operational problems — not commissioned, just necessary.
    </p>

    <div class="tools-grid">

      <!-- SortShelf -->
      <div class="tool-card">
        <div class="tool-card-header">
          <span class="tool-eyebrow">// Internal Tool</span>
          <span class="status-live">
            <span class="status-dot"></span>Live
          </span>
        </div>
        <div class="tool-body">
          <div class="tool-name">SortShelf</div>
          <div class="tool-subtitle">File Organization Utility · Windows</div>
          <p class="tool-desc">
            A lightweight Windows utility that automatically sorts a target folder by file type —
            documents, images, spreadsheets, scripts, and archives — into clean subdirectories.
            Includes live sort and one-step undo. Built after one too many chaotic Downloads folders.
          </p>
          <div class="tool-tags">
            <span class="tag">PowerShell</span>
            <span class="tag">Windows</span>
            <span class="tag">Automation</span>
            <span class="tag">CLI</span>
          </div>
        </div>
      </div>

      <!-- IT Logger -->
      <div class="tool-card">
        <div class="tool-card-header">
          <span class="tool-eyebrow">// Internal Tool</span>
          <span class="status-live">
            <span class="status-dot"></span>Live
          </span>
        </div>
        <div class="tool-body">
          <div class="tool-name">IT Logger</div>
          <div class="tool-subtitle">Internal Ticket Tracker · Local</div>
          <p class="tool-desc">
            A lightweight internal ticketing system built for environments that don't need — and
            won't adopt — enterprise helpdesk software. Logs issues, tracks status, and runs locally
            with zero external dependencies or licensing costs.
          </p>
          <div class="tool-tags">
            <span class="tag">Python</span>
            <span class="tag">Flask</span>
            <span class="tag">SQLite</span>
            <span class="tag">Internal Tooling</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ── CTA ── -->
<div class="cta-strip">
  <div class="cta-glow"></div>
  <div class="cta-eyebrow">// Work With Us</div>
  <h2 class="cta-headline">Your Project<br><em>Could Be Next.</em></h2>
  <p class="cta-sub">
    We take on a limited number of engagements at a time. If you have a problem worth solving,
    let's talk scope.
  </p>
  <div class="cta-actions">
    <a href="/contact" class="btn-primary">Start a Conversation</a>
    <a href="/services" class="btn-ghost">See What We Build</a>
  </div>
</div>

</Layout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    min-height: 52vh;
    padding-top: var(--nav-h);
    display: flex; align-items: center;
    position: relative; overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .page-hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 20%, transparent 100%);
    pointer-events: none;
  }
  .page-hero-glow {
    position: absolute; top: -10%; right: 5%;
    width: 700px; height: 500px;
    background: radial-gradient(ellipse, rgba(232,146,10,0.055) 0%, transparent 65%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    padding: 80px 48px; width: 100%;
  }
  .page-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 20px;
  }
  .page-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-size: clamp(64px, 8vw, 100px);
    line-height: 0.9; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--text);
    margin-bottom: 28px;
  }
  .page-headline em { font-style: normal; color: var(--accent); display: block; }
  .page-sub {
    font-size: 16px; line-height: 1.7; color: var(--muted);
    max-width: 480px; margin-bottom: 40px;
  }
  .page-hero-meta {
    display: flex; align-items: center; flex-wrap: wrap;
  }
  .meta-item {
    display: flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); padding: 0 20px 0 0;
  }
  .meta-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .meta-divider { width: 1px; height: 12px; background: var(--border2); margin-right: 20px; }

  /* ── FEATURED CARD ── */
  .featured-card {
    background: var(--bg3);
    border: 1px solid var(--border2);
    position: relative;
  }
  .featured-accent-bar {
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2) 40%, transparent);
  }
  .featured-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 28px 40px 0;
  }
  .featured-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted);
  }
  .status-live {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 5px 14px;
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.2);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: #4ade80;
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px rgba(74,222,128,0.6);
    animation: pulse-live 2s ease-in-out infinite;
  }
  @keyframes pulse-live {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.45; }
  }

  .featured-body {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    padding: 40px 40px 44px;
    align-items: start;
  }
  .featured-client {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800; font-size: clamp(36px, 4vw, 52px);
    letter-spacing: 0.01em; text-transform: uppercase;
    color: var(--text); line-height: 0.95;
    margin-bottom: 8px;
  }
  .featured-location {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted2); margin-bottom: 14px;
  }
  .featured-service {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 20px;
  }
  .featured-desc {
    font-size: 14px; line-height: 1.75; color: var(--muted);
    margin-bottom: 32px; max-width: 520px;
  }
  .featured-deliverables-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 14px;
  }
  .featured-deliverables {
    list-style: none; display: flex; flex-direction: column;
    gap: 8px; margin-bottom: 36px;
  }
  .featured-deliverables li {
    font-size: 13px; color: var(--muted); line-height: 1.5;
    padding-left: 18px; position: relative;
  }
  .featured-deliverables li::before {
    content: '—';
    position: absolute; left: 0;
    color: var(--muted2);
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
  }
  .featured-footer {
    display: flex; align-items: center;
    justify-content: space-between; gap: 20px;
    flex-wrap: wrap; padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .featured-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .featured-cta { white-space: nowrap; }

  /* ── BROWSER PREVIEW ── */
  .featured-preview {
    position: relative; align-self: center;
  }
  .browser-frame {
    background: var(--bg4);
    border: 1px solid var(--border2);
    overflow: hidden;
  }
  .browser-bar {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .browser-dots {
    display: flex; gap: 5px;
  }
  .browser-dots span {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--muted2); display: block;
  }
  .browser-url {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.08em;
    color: var(--muted2); flex: 1; text-align: center;
  }
  .browser-body { padding: 18px 16px 20px; }

  /* nav row */
  .brow-nav {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
  }
  .brow-logo {
    width: 72px; height: 7px;
    background: var(--muted2); border-radius: 1px;
  }
  .brow-nav-links { display: flex; gap: 8px; align-items: center; }

  /* hero content rows */
  .brow-hero { margin-bottom: 20px; }
  .brow-btn {
    width: 64px; height: 18px;
    background: var(--accent); opacity: 0.6;
    margin-top: 12px;
  }

  /* generic "line" shapes */
  .brow-line {
    height: 6px; background: var(--bg3); border-radius: 1px;
    margin-bottom: 7px;
  }
  .brow-line.xl   { width: 90%; }
  .brow-line.lg   { width: 75%; }
  .brow-line.md   { width: 60%; }
  .brow-line.sm   { width: 45%; }
  .brow-line.short { width: 28px; }
  .brow-line.muted { background: var(--bg4); }
  .brow-line.accent { background: var(--adim3); width: 40px; height: 16px; }

  /* bottom card row */
  .brow-cards {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 8px;
  }
  .brow-card {
    height: 44px;
    background: var(--bg);
    border: 1px solid var(--border);
  }

  .preview-tag {
    position: absolute; bottom: -16px; right: -16px;
    background: var(--bg2); border: 1px solid var(--border2);
    padding: 8px 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent);
  }

  /* ── PLACEHOLDER CARDS ── */
  .placeholders-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .placeholder-card {
    background: var(--bg3);
    padding: 40px 36px;
    position: relative;
    opacity: 0.45;
    filter: grayscale(0.3);
    cursor: default;
    transition: opacity 0.3s;
  }
  .placeholder-card:hover { opacity: 0.6; }
  .placeholder-lock {
    position: absolute; top: 40px; right: 36px;
    color: var(--muted2);
  }
  .placeholder-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.12em;
    color: var(--muted2); margin-bottom: 32px;
  }
  .placeholder-category {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 12px;
  }
  .placeholder-type {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; font-size: 22px;
    letter-spacing: 0.02em; text-transform: uppercase;
    color: var(--text); margin-bottom: 20px;
  }
  .placeholder-sector {
    font-size: 13px; color: var(--muted);
    display: flex; flex-direction: column; gap: 4px;
    margin-bottom: 28px;
  }
  .placeholder-sector-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted2); display: block;
  }
  .placeholder-status {
    display: flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.08em;
    color: var(--muted2);
  }
  .status-dot-dim {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--muted2); flex-shrink: 0;
  }

  .placeholders-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.06em; line-height: 1.7;
    color: var(--muted2); margin-top: 32px;
  }

  /* ── INTERNAL TOOLS ── */
  .tools-intro {
    font-size: 15px; line-height: 1.75; color: var(--muted);
    max-width: 560px; margin-bottom: 48px;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .tool-card {
    background: var(--bg3);
    transition: background 0.3s;
    cursor: default;
  }
  .tool-card:hover { background: var(--bg4); }
  .tool-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 28px 36px 0;
  }
  .tool-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted);
  }
  .tool-body {
    padding: 20px 36px 36px;
  }
  .tool-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800; font-size: clamp(32px, 3vw, 44px);
    letter-spacing: 0.01em; text-transform: uppercase;
    color: var(--text); line-height: 0.95;
    margin-bottom: 10px;
  }
  .tool-subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 20px;
  }
  .tool-desc {
    font-size: 14px; line-height: 1.75; color: var(--muted);
    margin-bottom: 28px;
  }
  .tool-tags { display: flex; flex-wrap: wrap; gap: 6px; }

  /* ── CTA STRIP ── */
  .cta-strip {
    padding: 100px 48px;
    text-align: center;
    position: relative; overflow: hidden;
    background: var(--bg);
  }
  .cta-glow {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 800px; height: 400px;
    background: radial-gradient(ellipse, rgba(232,146,10,0.06) 0%, transparent 60%);
    pointer-events: none;
  }
  .cta-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 20px;
    position: relative; z-index: 1;
  }
  .cta-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-size: clamp(48px, 6vw, 80px);
    line-height: 0.92; text-transform: uppercase;
    color: var(--text); margin-bottom: 20px;
    position: relative; z-index: 1;
  }
  .cta-headline em { font-style: normal; color: var(--accent); display: block; }
  .cta-sub {
    font-size: 15px; color: var(--muted); margin-bottom: 44px;
    max-width: 460px; margin-inline: auto; line-height: 1.7;
    position: relative; z-index: 1;
  }
  .cta-actions {
    display: flex; gap: 16px; justify-content: center;
    align-items: center; flex-wrap: wrap;
    position: relative; z-index: 1;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .page-hero-inner { padding: 60px 24px; }
    .featured-body { grid-template-columns: 1fr; gap: 40px; }
    .featured-preview { display: none; }
    .featured-header { padding: 24px 24px 0; }
