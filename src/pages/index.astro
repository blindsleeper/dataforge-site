---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Data Analytics & Web Consulting">

<!-- HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-eyebrow fade-up d1">Wichita, KS — Data & Web Consulting</div>
      <h1 class="hero-headline fade-up d2">
        Your Data.<br>
        <em>Your Edge.</em>
      </h1>
      <p class="hero-sub fade-up d3">
        DataForge builds the <strong>analytics systems, automated workflows, and web infrastructure</strong>
        that turn raw business data into measurable growth — without the enterprise price tag.
      </p>
      <div class="hero-actions fade-up d4">
        <a href="/portfolio" class="btn-primary">See Our Work</a>
        <a href="/contact" class="btn-ghost">Start a Project</a>
      </div>
    </div>
    <div class="hero-right fade-up d5">
      <div style="position:relative;">
        <div class="data-card">
          <div class="data-card-label">// client performance snapshot</div>
          <div class="data-metrics">
            <div class="metric"><div class="metric-val">3.4×</div><div class="metric-label">Report Speed</div></div>
            <div class="metric"><div class="metric-val">91%</div><div class="metric-label">Process Reduction</div></div>
            <div class="metric"><div class="metric-val">12h</div><div class="metric-label">Saved Weekly</div></div>
            <div class="metric"><div class="metric-val">100%</div><div class="metric-label">On-Time Delivery</div></div>
          </div>
          <div class="data-bars">
            <div class="bar-row"><span class="bar-label">Analytics</span><div class="bar-track"><div class="bar-fill" style="width:88%;animation-delay:0.8s"></div></div><span class="bar-pct">88%</span></div>
            <div class="bar-row"><span class="bar-label">Systems</span><div class="bar-track"><div class="bar-fill" style="width:76%;animation-delay:0.95s"></div></div><span class="bar-pct">76%</span></div>
            <div class="bar-row"><span class="bar-label">Web</span><div class="bar-track"><div class="bar-fill" style="width:94%;animation-delay:1.1s"></div></div><span class="bar-pct">94%</span></div>
          </div>
        </div>
        <div class="floating-tag">Live Client Data</div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-item"><span class="trust-dot"></span>Wichita, KS Based</div>
  <div class="trust-item"><span class="trust-dot"></span>Data Analytics</div>
  <div class="trust-item"><span class="trust-dot"></span>Process Automation</div>
  <div class="trust-item"><span class="trust-dot"></span>Web & CMS</div>
  <div class="trust-item"><span class="trust-dot"></span>AI-Augmented Workflows</div>
</div>

<!-- SERVICES -->
<div id="services" style="border-bottom: 1px solid var(--border);">
  <div class="section">
    <div class="section-header">
      <span class="section-num">01</span>
      <h2 class="section-title">What We<br><em>Build</em></h2>
    </div>
    <div class="section-rule"></div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18M7 16l4-4 4 4 4-8"/></svg>
        </div>
        <span class="service-num">01</span>
        <div class="service-name">Data Analytics</div>
        <div class="service-desc">Transform scattered business data into dashboards and reports that actually drive decisions.</div>
        <div class="service-tags"><span class="tag">Dashboards</span><span class="tag">SQL</span><span class="tag">Reporting</span><span class="tag">KPI Tracking</span></div>
        <span class="service-arrow">↗</span>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="1"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <span class="service-num">02</span>
        <div class="service-name">Systems & Automation</div>
        <div class="service-desc">Build backend infrastructure that eliminates manual work — custom tools, automated workflows, scalable integrations.</div>
        <div class="service-tags"><span class="tag">Automation</span><span class="tag">Integrations</span><span class="tag">Custom Tools</span><span class="tag">AI Workflows</span></div>
        <span class="service-arrow">↗</span>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </div>
        <span class="service-num">03</span>
        <div class="service-name">Web & CMS</div>
        <div class="service-desc">Professional websites and CMS platforms that convert visitors into clients. Hand-coded or Webflow — built to perform.</div>
        <div class="service-tags"><span class="tag">Webflow</span><span class="tag">Custom Dev</span><span class="tag">CMS</span><span class="tag">Performance</span></div>
        <span class="service-arrow">↗</span>
      </div>
    </div>
    <div style="margin-top:32px;text-align:right;">
      <a href="/services" class="btn-ghost">View All Services + Pricing →</a>
    </div>
  </div>
</div>

<!-- CTA STRIP -->
<div style="background:var(--bg2);border-bottom:1px solid var(--border);padding:100px 48px;text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:800px;height:400px;background:radial-gradient(ellipse,rgba(232,146,10,0.06) 0%,transparent 60%);pointer-events:none;"></div>
  <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);margin-bottom:20px;position:relative;z-index:1;">// Ready to Build</div>
  <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(48px,6vw,80px);line-height:0.92;text-transform:uppercase;color:var(--text);margin-bottom:20px;position:relative;z-index:1;">Forge Your<br>Competitive Edge.</h2>
  <p style="font-size:16px;color:var(--muted);margin-bottom:44px;position:relative;z-index:1;">A 30-minute call costs nothing. Let's find out what's possible.</p>
  <div style="display:flex;gap:16px;justify-content:center;align-items:center;flex-wrap:wrap;position:relative;z-index:1;">
    <a href="/contact" class="btn-primary">Start a Conversation</a>
    <a href="mailto:hello@dataforgewichita.com" style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:0.08em;color:var(--muted);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted)'">hello@dataforgewichita.com</a>
  </div>
</div>

</Layout>

<style>
  .hero {
    min-height: 100vh; padding-top: var(--nav-h);
    display: flex; align-items: center; position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
    pointer-events: none;
  }
  .hero-glow { position: absolute; top: 15%; right: -5%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(232,146,10,0.07) 0%, transparent 65%); pointer-events: none; }
  .hero-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 48px; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 28px; }
  .hero-eyebrow::before { content: ''; display: block; width: 28px; height: 1px; background: var(--accent); }
  .hero-headline { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: clamp(72px, 8vw, 108px); line-height: 0.9; letter-spacing: -0.01em; text-transform: uppercase; color: var(--text); margin-bottom: 32px; }
  .hero-headline em { font-style: normal; color: var(--accent); display: block; }
  .hero-sub { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 420px; margin-bottom: 44px; }
  .hero-sub strong { color: var(--text); font-weight: 500; }
  .hero-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .data-card { background: var(--bg3); border: 1px solid var(--border2); padding: 28px 32px; width: 100%; max-width: 380px; position: relative; }
  .data-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--accent), transparent); }
  .data-card-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 20px; }
  .data-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
  .metric { padding: 16px; background: var(--bg4); border: 1px solid var(--border); }
  .metric-val { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 32px; color: var(--accent); line-height: 1; margin-bottom: 4px; }
  .metric-label { font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }
  .data-bars { display: flex; flex-direction: column; gap: 8px; }
  .bar-row { display: flex; align-items: center; gap: 10px; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--muted); }
  .bar-label { width: 80px; flex-shrink: 0; }
  .bar-track { flex: 1; height: 4px; background: var(--bg4); position: relative; }
  .bar-fill { position: absolute; left: 0; top: 0; bottom: 0; background: var(--accent); transform-origin: left; animation: barGrow 1.2s cubic-bezier(0.25,0.46,0.45,0.94) both; }
  .bar-pct { width: 28px; text-align: right; }
  @keyframes barGrow { from { transform: scaleX(0); } to { transform: scaleX(1); } }
  .floating-tag { position: absolute; bottom: -24px; right: -24px; background: var(--bg2); border: 1px solid var(--border2); padding: 12px 18px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; padding: 40px 24px; }
    .hero-right { display: none; }
  }
</style>
